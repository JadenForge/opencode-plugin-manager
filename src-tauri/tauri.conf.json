{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "opencode-plugin-manager",
  "version": "0.4.4",
  "identifier": "com.jadenforge.opencode-plugin-manager",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "opencode-plugin-manager",
        "width": 960,
        "height": 720,
        "minWidth": 720,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM1MzU0MDEwNDMzNUFGMTMKUldRVHJ6VkRFRUExeGNvRFJ4blJ0eEttQTQrL3R3MEhOQnFWQ2Z5aTdvTFVHblhzVllLS3k2VVIK",
      "endpoints": [
        "https://github.com/JadenForge/opencode-plugin-manager/releases/latest/download/latest.json"
      ]
    }
  }
}
